#!/usr/bin/env bash
# tools/oric-build
# Compile the Oric core in a Quartus Docker image and deploy to MiSTer.
# Run from the repo root.
#
# Usage: oric-build [--no-deploy] [--clean] [--no-hdmi] [--snap-debug]
#   --no-deploy   compile only, don't push to MiSTer
#   --clean       wipe Quartus build dirs before compiling
#   --no-hdmi     define MISTER_DEBUG_NOHDMI for faster dev compiles
#   --snap-debug  define SNAP_DEBUG to paint captured CPU regs at row 10
#                 of the text screen after a snapshot load

set -euo pipefail

# === Config ===
MISTER_HOST="root@192.168.0.108"
MISTER_DEV_DIR="/media/fat/_Aoric"
MISTER_OFFICIAL_DIR="/media/fat/_Computer"
CORE_NAME="Oric"
QPF_FILE="${CORE_NAME}.qpf"
RBF_OUT="output_files/${CORE_NAME}.rbf"
DOCKER_IMAGE="raetro/quartus:mister"

# === Parse args ===
DEPLOY=1
CLEAN=0
MACROS=()
for arg in "$@"; do
    case "$arg" in
        --no-deploy)  DEPLOY=0 ;;
        --clean)      CLEAN=1 ;;
        --no-hdmi)    MACROS+=("MISTER_DEBUG_NOHDMI=1") ;;
        --snap-debug) MACROS+=("SNAP_DEBUG=1") ;;
        -h|--help)
            sed -n '2,11p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "unknown arg: $arg" >&2; exit 2 ;;
    esac
done

# === Sanity: must be in repo root ===
if [[ ! -f "${QPF_FILE}" ]]; then
    echo "ERROR: ${QPF_FILE} not found. Run from the Oric_MiSTer repo root." >&2
    exit 1
fi

REPO_ROOT="$(pwd)"
: "${REPO_ROOT:?REPO_ROOT not set}"

QSF_BACKUP=""
MACROS_TCL=""
cleanup_build_files() {
    local rc=$?
    if [[ -n "${QSF_BACKUP}" && -f "${QSF_BACKUP}" ]]; then
        cp "${QSF_BACKUP}" "${CORE_NAME}.qsf"
        rm -f "${QSF_BACKUP}"
    fi
    if [[ -n "${MACROS_TCL}" && -f "${MACROS_TCL}" ]]; then
        rm -f "${MACROS_TCL}"
    fi
    return "${rc}"
}

# === Optional: clean build dirs ===
if [[ ${CLEAN} -eq 1 ]]; then
    echo ">>> Cleaning Quartus build directories..."
    rm -rf db incremental_db output_files
fi

QSF_BACKUP="$(mktemp)"
cp "${CORE_NAME}.qsf" "${QSF_BACKUP}"
trap cleanup_build_files EXIT INT TERM

# === Compile ===
echo ">>> Compiling ${CORE_NAME} (this takes 15–40 minutes)..."
START=$(date +%s)

if [[ ${#MACROS[@]} -gt 0 ]]; then
    echo ">>> Building with Verilog macros: ${MACROS[*]}"
    MACROS_TCL="$(mktemp)"

    # Inject macros via a tiny TCL script, then restore the pre-build qsf
    # from the backup even if Quartus fails or the build is interrupted.
    {
        echo "project_open ${CORE_NAME}"
        for m in "${MACROS[@]}"; do
            echo "set_global_assignment -name VERILOG_MACRO \"${m}\""
        done
        echo "project_close"
    } > "${MACROS_TCL}"
    docker run --rm \
        --user "$(id -u):$(id -g)" \
        -v "${REPO_ROOT}:/build" \
        -v "${MACROS_TCL}:/tmp/oric_macros.tcl" \
        -w /build \
        "${DOCKER_IMAGE}" \
        bash -c "quartus_sh -t /tmp/oric_macros.tcl && quartus_sh --flow compile ${QPF_FILE}"
else
    docker run --rm \
        --user "$(id -u):$(id -g)" \
        -v "${REPO_ROOT}:/build" \
        -w /build \
        "${DOCKER_IMAGE}" \
        quartus_sh --flow compile "${QPF_FILE}"
fi

cleanup_build_files
trap - EXIT INT TERM

ELAPSED=$(( $(date +%s) - START ))
printf ">>> Compile finished in %dm%ds\n" $((ELAPSED/60)) $((ELAPSED%60))

# === Verify output ===
if [[ ! -f "${RBF_OUT}" ]]; then
    echo "ERROR: ${RBF_OUT} not found after compile." >&2
    exit 1
fi
RBF_SIZE=$(stat -c %s "${RBF_OUT}")
printf ">>> Built %s (%d bytes)\n" "${RBF_OUT}" "${RBF_SIZE}"

# === Deploy ===
if [[ ${DEPLOY} -eq 0 ]]; then
    echo ">>> --no-deploy set; skipping upload."
    exit 0
fi

# Tag with timestamp + short git sha for traceability
STAMP="$(date +%Y%m%d_%H%M%S)"
SHA="$(git rev-parse --short HEAD 2>/dev/null || echo nogit)"
REMOTE_NAME="${CORE_NAME}_${STAMP}_${SHA}.rbf"

OFFICIAL_NAME="${CORE_NAME}_$(date +%Y%m%d).rbf"

echo ">>> Deploying dev core to ${MISTER_HOST}:${MISTER_DEV_DIR}/${REMOTE_NAME}"

ssh -o StrictHostKeyChecking=accept-new "${MISTER_HOST}" \
    "mkdir -p '${MISTER_DEV_DIR}' '${MISTER_OFFICIAL_DIR}'"

scp "${RBF_OUT}" \
    "${MISTER_HOST}:${MISTER_DEV_DIR}/${REMOTE_NAME}"

# Drop a stable name for "latest" so MiSTer always finds something
ssh "${MISTER_HOST}" \
    "cp '${MISTER_DEV_DIR}/${REMOTE_NAME}' '${MISTER_DEV_DIR}/${CORE_NAME}.rbf'"

echo ">>> Deploying official core to ${MISTER_HOST}:${MISTER_OFFICIAL_DIR}/${OFFICIAL_NAME}"

ssh "${MISTER_HOST}" \
    "rm -f '${MISTER_OFFICIAL_DIR}/${CORE_NAME}.rbf' '${MISTER_OFFICIAL_DIR}/${CORE_NAME}'_*.rbf"

scp "${RBF_OUT}" \
    "${MISTER_HOST}:${MISTER_OFFICIAL_DIR}/${OFFICIAL_NAME}"

echo ">>> Done."
echo "    ${MISTER_DEV_DIR}/${REMOTE_NAME}       (dev timestamped)"
echo "    ${MISTER_DEV_DIR}/${CORE_NAME}.rbf     (dev latest)"
echo "    ${MISTER_OFFICIAL_DIR}/${OFFICIAL_NAME}  (official)"
